# ─────────────────────────────────────────────────────────────────────────────
# SODP server configuration
#
# Copy this file to .env and edit before running `docker compose up`.
# Commented-out variables show their default value; uncomment to override.
# ─────────────────────────────────────────────────────────────────────────────


# ── Authentication ────────────────────────────────────────────────────────────
#
# OPTION A — HS256 shared secret (simpler, good for single-service setups)
#   Generate a secret: openssl rand -base64 48
SODP_JWT_SECRET=

# OPTION B — RS256 public key file (recommended for multi-service setups)
#   Place your PEM file in ./config/ and set the path inside the container.
#   Takes priority over SODP_JWT_SECRET when set.
# SODP_JWT_PUBLIC_KEY_FILE=/etc/sodp/jwt_public.pem

# Leave both blank to disable authentication (dev/local only — never in prod).


# ── Ports ─────────────────────────────────────────────────────────────────────
#
# Host port the WebSocket server listens on (clients connect here).
SODP_PORT=7777

# Internal health check port — do NOT expose publicly (used by load balancers).
SODP_HEALTH_PORT=7778

# Internal Prometheus metrics port — do NOT expose publicly.
SODP_METRICS_PORT=9090


# ── Access control ────────────────────────────────────────────────────────────
#
# Path to ACL rules JSON file *inside the container*.
# Place acl.json in ./config/ — it is mounted at /etc/sodp/.
# See docs/guide.md §9 for the ACL rule format.
# SODP_ACL_FILE=/etc/sodp/acl.json


# ── Rate limiting ─────────────────────────────────────────────────────────────
#
# Maximum state.set / state.patch / state.set_in / state.delete calls
# per session per second. Excess frames receive ERROR 429. Unlimited if unset.
# SODP_RATE_WRITES_PER_SEC=100

# Maximum WATCH + RESUME frames per session per second. Unlimited if unset.
# SODP_RATE_WATCHES_PER_SEC=50


# ── Connection limits ─────────────────────────────────────────────────────────
#
# Maximum concurrent WebSocket connections. New connections are rejected when
# the limit is reached. Unlimited if unset.
# SODP_MAX_CONNECTIONS=10000

# Maximum inbound frame size in bytes. Frames over the limit receive ERROR 413
# and the connection is closed. Default: 1 MiB.
# SODP_MAX_FRAME_BYTES=1048576


# ── Keep-alive ────────────────────────────────────────────────────────────────
#
# Seconds between WebSocket ping frames. Sessions that miss a pong are closed.
# SODP_WS_PING_INTERVAL=25


# ── Horizontal scaling (Redis) ────────────────────────────────────────────────
#
# Enable with:  docker compose --profile cluster up
#
# Redis connection URL. When set, state is shared across nodes via a Redis hash
# and cross-node delta fanout runs over Redis Pub/Sub.
# Absent = single-node mode (no Redis dependency, no extra latency).
# SODP_REDIS_URL=redis://redis:6379/


# ── Logging ───────────────────────────────────────────────────────────────────
#
# Log level: error | warn | info | debug | trace
RUST_LOG=info
