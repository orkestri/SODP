{
  "name": "@sodp/server",
  "version": "0.1.0",
  "description": "TypeScript server library for the State-Oriented Data Protocol",
  "main": "dist/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && tsc -p tsconfig.esm.json && node -e \"require('fs').writeFileSync('dist/esm/package.json', '{\\\"type\\\":\\\"module\\\"}')\"",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "bench": "npx ts-node bench/bench.ts",
    "bench:quick": "npx ts-node bench/bench.ts quick"
  },
  "keywords": [
    "sodp",
    "realtime",
    "state-sync",
    "websocket",
    "server"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/orkestri/SODP.git",
    "directory": "server-ts"
  },
  "homepage": "https://github.com/orkestri/SODP/tree/main/server-ts#readme",
  "bugs": {
    "url": "https://github.com/orkestri/SODP/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.0.0",
    "jose": "^5.0.0",
    "ws": "^8.0.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.0.0",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  }
}
